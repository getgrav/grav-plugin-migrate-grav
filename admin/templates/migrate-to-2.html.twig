{% extends 'partials/base.html.twig' %}

{% block titlebar %}
    <div class="button-bar">
        <a class="btn" href="https://github.com/getgrav/grav-plugin-migrate-to-2" target="_blank">
            <i class="fa fa-question-circle"></i> Help
        </a>
    </div>
    <h1><i class="fa fa-rocket"></i> Migrate to Grav 2.0</h1>
{% endblock %}

{% block content %}
    <div class="admin-block">
        <p>
            This will stage a fresh Grav 2.0 install in <code>/{{ config.plugins['migrate-to-2'].stage_dir }}/</code>
            alongside your current site, then hand you off to a standalone migration wizard
            running outside of this Grav process.
        </p>

        <p>
            <strong>Nothing is changed in your current site</strong> until you complete and explicitly
            promote the new install. You can abandon the migration at any time by removing the
            <code>.migrating</code> file and the staged directory.
        </p>

        <form method="post" action="{{ base_url_relative }}/task:taskMigrateToTwoInit">
            <input type="hidden" name="admin-nonce" value="{{ admin.getNonce('admin-form') }}" />
            <button type="submit" class="button">
                <i class="fa fa-play"></i> Stage Grav 2.0 and start wizard
            </button>
        </form>

        <hr />

        <h3>What this does</h3>
        <ol>
            <li>Downloads the latest Grav 2.0 release.</li>
            <li>Drops a standalone <code>migrate.php</code> file at your webroot.</li>
            <li>Saves the 2.0 release zip to <code>tmp/</code> for the wizard to extract.</li>
            <li>Writes a single-use token to <code>.migrating</code>.</li>
            <li>Redirects you to <code>/migrate.php</code> &mdash; your browser leaves Grav 1.x entirely from this point on.</li>
        </ol>

        <h3>Prefer the CLI?</h3>
        <p>Run <code>bin/plugin migrate-to-2 init</code> from your site root.</p>
    </div>
{% endblock %}
